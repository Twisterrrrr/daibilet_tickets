# ============================================
# Дайбилет — переменные окружения
# ============================================
# Скопируй этот файл как .env и заполни значения.
# Для production — все переменные обязательны (кроме отмеченных «опционально»).
#
# PRODUCTION CHECKLIST:
# [ ] NODE_ENV=production
# [ ] APP_URL=https://daibilet.ru
# [ ] POSTGRES_PASSWORD — сгенерировать (min 24 chars): openssl rand -base64 24
# [ ] REDIS_PASSWORD — сгенерировать: openssl rand -base64 24
# [ ] JWT_SECRET — сгенерировать (min 32 chars): openssl rand -base64 48
# [ ] TC_API_TOKEN — получить из Ticketscloud
# [ ] TC_WIDGET_TOKEN — получить из Ticketscloud
# [ ] ADMIN_INITIAL_PASSWORD — надёжный пароль (min 12 chars)
# [ ] CORS_ORIGIN=https://daibilet.ru,https://admin.daibilet.ru

# ---- Общие ----
NODE_ENV=development
APP_URL=http://localhost:3000

# ---- PostgreSQL ----
POSTGRES_DB=daibilet
POSTGRES_USER=daibilet
POSTGRES_PASSWORD=daibilet_dev
# В dev: указать host:port напрямую; в Docker production — собирается из переменных выше
DATABASE_URL=postgresql://daibilet:daibilet_dev@localhost:5433/daibilet

# ---- Redis ----
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ---- Ticketscloud ----
TC_API_URL=https://ticketscloud.com/v2
TC_API_TOKEN=
TC_WIDGET_TOKEN=

# gRPC tc-simple (каталог событий)
# prod: simple.ticketscloud.com:443
# stage: simple.stage.freetc.net:443
TC_GRPC_ENDPOINT=simple.ticketscloud.com:443
# Режим синхронизации каталога: "grpc" (рекомендуется) или "rest" (fallback на REST v1)
TC_SYNC_MODE=grpc

# ---- Frontend (Next.js) ----
# SSR: адрес backend внутри Docker network
INTERNAL_API_URL=http://localhost:4000/api/v1
# CSR: публичный адрес API (через Nginx или rewrites)
NEXT_PUBLIC_API_URL=/api/v1
# Публичный URL сайта (для OG-тегов, sitemap)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Токен виджета TC для frontend
NEXT_PUBLIC_TC_WIDGET_TOKEN=

# ---- Яндекс Метрика ----
# ID счётчика (создаётся на https://metrika.yandex.ru)
NEXT_PUBLIC_YM_ID=106786540

# ---- JWT (админ-панель) ----
JWT_SECRET=change-me-to-random-string-min-32-chars
ADMIN_INITIAL_EMAIL=admin@daibilet.ru
ADMIN_INITIAL_PASSWORD=changeme123

# ---- CORS ----
# Через запятую: public site + admin panel
# Production: https://daibilet.ru,https://admin.daibilet.ru
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ---- Email / SMTP (опционально) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@daibilet.ru
ADMIN_EMAIL=admin@daibilet.ru

# ---- Загрузка файлов ----
# Директория хранения загруженных файлов (по умолчанию: ./uploads)
UPLOAD_DIR=
# Публичный путь для доступа к файлам (по умолчанию: /uploads)
UPLOAD_PUBLIC_PATH=/uploads

# ---- Мониторинг (опционально) ----
SENTRY_DSN=
