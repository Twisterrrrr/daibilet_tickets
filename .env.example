# ============================================
# Дайбилет — переменные окружения
# ============================================
# ИСТОЧНИК ИСТИНЫ: этот файл — полный список переменных.
# Скопируй как .env и заполни значения.
# Для production — см. PRODUCTION CHECKLIST ниже и docs/PreDeployChecklist.md.
#
# PRODUCTION CHECKLIST:
# [ ] NODE_ENV=production
# [ ] APP_URL=https://daibilet.ru
# [ ] POSTGRES_PASSWORD — сгенерировать (min 24 chars): openssl rand -base64 24
# [ ] REDIS_PASSWORD — сгенерировать: openssl rand -base64 24
# [ ] JWT_SECRET — сгенерировать (min 32 chars): openssl rand -base64 48
# [ ] TC_API_TOKEN — получить из Ticketscloud
# [ ] TC_WIDGET_TOKEN — получить из Ticketscloud
# [ ] ADMIN_INITIAL_PASSWORD — надёжный пароль (min 12 chars)
# [ ] CORS_ORIGIN=https://daibilet.ru,https://admin.daibilet.ru

# ============ Database ============
# PostgreSQL connection string
# В dev: указать host:port напрямую; в Docker production — собирается из переменных ниже
DATABASE_URL=postgresql://daibilet:daibilet_dev@localhost:5433/daibilet

# PostgreSQL credentials (используются для сборки DATABASE_URL в Docker)
POSTGRES_DB=daibilet
POSTGRES_USER=daibilet
POSTGRES_PASSWORD=daibilet_dev

# ============ Redis ============
# Redis connection URL
REDIS_URL=redis://localhost:6379
# Redis password (опционально, если Redis требует аутентификацию)
REDIS_PASSWORD=

# ============ Application ============
# Node environment: development | production
NODE_ENV=development

# Backend server port
PORT=4000

# Public URL of the application (used for email links, redirects, etc.)
# Production: https://daibilet.ru
# Dev: http://localhost:3000
APP_URL=http://localhost:3000

# CORS allowed origins (comma-separated). CORS_ORIGINS — альтернативное имя
# Production: https://daibilet.ru,https://admin.daibilet.ru
# Dev: без env — localhost:3000,3001,5173
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============ Auth ============
# JWT secret for admin panel authentication (min 32 characters)
# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-random-string-min-32-chars

# Initial admin user credentials (used during first seed)
ADMIN_INITIAL_EMAIL=admin@daibilet.ru
ADMIN_INITIAL_PASSWORD=changeme123

# ============ Email (SMTP) ============
# SMTP configuration (опционально — если не настроено, email отправка отключена)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Email sender address
EMAIL_FROM=noreply@daibilet.ru
# Admin email for notifications
ADMIN_EMAIL=admin@daibilet.ru

# ============ External APIs ============
# Ticketscloud API configuration
TC_API_URL=https://ticketscloud.com/v2
TC_API_TOKEN=
TC_WIDGET_TOKEN=

# gRPC tc-simple (каталог событий)
# prod: simple.ticketscloud.com:443
# stage: simple.stage.freetc.net:443
TC_GRPC_ENDPOINT=simple.ticketscloud.com:443

# Режим синхронизации каталога: "grpc" (рекомендуется) или "rest" (fallback на REST v1)
TC_SYNC_MODE=grpc

# ============ Payment ============
# Payment provider: STUB (dev/testing) | YOOKASSA (production)
# STUB creates mock payment URLs for testing
PAYMENT_PROVIDER=STUB

# ============ Frontend ============
# Backend API URL for SSR (server-side requests within Docker network)
INTERNAL_API_URL=http://localhost:4000/api/v1

# Public API URL for CSR (client-side requests, can be relative path)
NEXT_PUBLIC_API_URL=/api/v1

# Public site URL (used in sitemap, robots.txt, OG tags)
# Production: https://daibilet.ru
# Dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Ticketscloud widget token for frontend
NEXT_PUBLIC_TC_WIDGET_TOKEN=

# Яндекс Метрика — ID счётчика (создаётся на https://metrika.yandex.ru)
NEXT_PUBLIC_YM_ID=106786540

# ============ File Upload ============
# Директория хранения загруженных файлов (по умолчанию: ./uploads)
UPLOAD_DIR=
# Публичный путь для доступа к файлам (по умолчанию: /uploads)
UPLOAD_PUBLIC_PATH=/uploads

# ============ Monitoring ============
# Sentry DSN for error tracking (опционально)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ============ Feature Flags ============
# Kill switch: disable legacy PurchaseType compatibility
# Set to "true" to disable legacy PurchaseType values (will throw errors)
DISABLE_PURCHASE_TYPE_COMPAT=false
