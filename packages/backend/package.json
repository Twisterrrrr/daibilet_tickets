{
  "name": "@daibilet/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:tep-widgets": "npx tsx prisma/seed-teplohod-widgets.ts",
    "db:seed:regions": "npx tsx prisma/seed-regions.ts",
    "db:seed:qf": "npx tsx prisma/seed-query-filters.ts",
    "db:seed:seo": "npx tsx prisma/seed-seo-templates.ts",
    "sync:tep": "npx tsx scripts/sync-teplohod.ts",
    "full:sync": "npx tsx scripts/full-sync.ts",
    "backfill:grouping": "npx tsx scripts/backfill-event-grouping.ts",
    "event-groups:create": "npx tsx scripts/auto-create-event-groups.ts",
    "reclassify:dry": "npx tsx prisma/reclassify-events.ts",
    "reclassify:apply": "npx tsx prisma/reclassify-events.ts --apply",
    "check:categorization": "npx tsx prisma/check-categorization.ts",
    "fix:teplohod-river": "npx tsx prisma/fix-teplohod-river-excursions.ts",
    "gen:proto": "node -e \"require('fs').mkdirSync('src/generated',{recursive:true})\" && protoc --plugin=protoc-gen-ts_proto=./node_modules/ts-proto/protoc-gen-ts_proto --ts_proto_out=./src/generated --ts_proto_opt=esModuleInterop=true --ts_proto_opt=outputServices=false -I ./proto/tc-simple -I ./node_modules/google-proto-files ./proto/tc-simple/events.proto ./proto/tc-simple/venues.proto ./proto/tc-simple/geo.proto ./proto/tc-simple/generic.proto ./proto/tc-simple/meta_events.proto ./proto/tc-simple/mods.proto",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@daibilet/shared": "workspace:*",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.3.0",
    "@sentry/nestjs": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.30.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "nestjs-pino": "^4.6.0",
    "nodemailer": "^8.0.1",
    "p-limit": "^6.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^16.4.5",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.3.0",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
