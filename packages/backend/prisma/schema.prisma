// ==============================================
// Дайбилет — Prisma Schema
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// Enums
// ========================

enum EventSource {
  TC // Ticketscloud
  TEPLOHOD // teplohod.info
  MANUAL // Ручной ввод через админку
}

enum EventCategory {
  EXCURSION // Экскурсии
  MUSEUM // Музеи и выставки
  EVENT // Мероприятия (концерты, шоу, театр, спорт, фестивали)
}

enum EventAudience {
  ALL // Для всех
  KIDS // Детям
  FAMILY // Семейный
}

enum EventSubcategory {
  // EXCURSION
  RIVER // Речная экскурсия
  WALKING // Пешеходная
  BUS // Автобусная
  COMBINED // Комбинированная
  QUEST // Квест-экскурсия
  GASTRO // Гастро-экскурсия
  ROOFTOP // Крыши
  EXTREME // Экстрим (танк, квадроцикл, стрельба и т.п.)
  // MUSEUM
  MUSEUM_CLASSIC // Музей
  EXHIBITION // Выставка
  GALLERY // Галерея
  PALACE // Дворец / Усадьба
  PARK // Парк / Заповедник
  ART_SPACE // Арт-пространство
  SCULPTURE // Скульптура
  CONTEMPORARY // Современное искусство
  // EVENT
  CONCERT // Концерт
  SHOW // Шоу / Представление
  STANDUP // Стендап
  THEATER // Театр / Спектакль
  SPORT // Спорт
  FESTIVAL // Фестиваль
  MASTERCLASS // Мастер-класс
  PARTY // Вечеринка
}

enum TagCategory {
  THEME // "Романтика", "Гастро", "Фото"
  AUDIENCE // "С детьми", "Для двоих", "Для компании"
  SEASON // "Зимой", "Летом", "Белые ночи"
  SPECIAL // "Новинка", "Хит продаж", "Скидка"
}

enum Intensity {
  RELAXED
  NORMAL
  ACTIVE
}

enum DaySlot {
  MORNING // 09:00-12:00
  AFTERNOON // 13:00-17:00
  EVENING // 18:00-22:00
}

enum PackageStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FULFILLING
  FULFILLED
  PARTIALLY_FULFILLED
  FAILED
  REFUNDED
}

enum PackageItemStatus {
  PENDING
  BOOKED
  CONFIRMED
  FAILED
  REFUNDED
}

enum AdminRole {
  ADMIN
  EDITOR
  VIEWER
}

enum SupplierRole {
  OWNER // Полный доступ + настройки
  MANAGER // Управление событиями/заявками
  CONTENT // Создание и правка контента
  ACCOUNTANT // Отчёты и выплаты (read-only)
}

enum OperatorStatus {
  ACTIVE // Активный контрагент
  ARCHIVED // Юрлицо закрыто
  SUSPENDED // Временно приостановлен
}

enum ModerationStatus {
  DRAFT // Черновик (поставщик ещё не отправил)
  PENDING_REVIEW // Ожидает модерации (trust level 0)
  APPROVED // Одобрено админом
  REJECTED // Отклонено (с причиной)
  AUTO_APPROVED // Автоодобрено (trust level 1-2)
}

/// Очередь постредакции: статус правок поверх импортного события (редактор в админке)
enum EditorStatus {
  NEEDS_REVIEW // Импорт: нужна проверка редактором
  IN_PROGRESS  // Редактор в работе
  PUBLISHED    // Опубликовано (sync не сбрасывает)
  REJECTED     // Отклонено
}

enum SubcategoriesMode {
  INHERIT
  OVERRIDE
  CLEAR
}

enum LocationType {
  PIER // Причал
  VENUE // Площадка
  MEETING_POINT // Точка встречи
  OTHER
}

enum VenueType {
  MUSEUM // Музей
  GALLERY // Галерея
  ART_SPACE // Арт-пространство
  EXHIBITION_HALL // Выставочный зал
  THEATER // Театр
  PALACE // Дворец / Усадьба
  PARK // Парк / Заповедник
}

enum DateMode {
  SCHEDULED // Обычные события с сеансами
  OPEN_DATE // Билет с открытой датой (музеи)
}

// --- Мульти-офферная архитектура ---

enum OfferSource {
  TC
  TEPLOHOD
  RADARIO
  TIMEPAD
  MANUAL
}

enum OfferStatus {
  ACTIVE
  HIDDEN
  DISABLED
}

enum PurchaseType {
  WIDGET // Встроенный виджет покупки (Ticketscloud и др.)
  REDIRECT // Внешний URL (teplohod.info и т.п.)
  REQUEST // Заявка на подтверждение (без прямой оплаты)
}

/// Режим ценообразования для оффера (фиксированная цена или свободная сумма)
enum PriceMode {
  FIXED_PRICE
  OPEN_PRICE
}

/// Режим действия билета/ваучера
enum ValidityMode {
  NO_EXPIRY // бессрочно
  UNTIL_DATE // до фиксированной даты
  DAYS_FROM_PURCHASE // N дней с момента покупки
}

enum ReviewStatus {
  PENDING_EMAIL // Ожидает подтверждения email
  PENDING // Email подтверждён, ожидает модерации
  APPROVED
  REJECTED
}

enum CreatedByType {
  ADMIN
  SUPPLIER
  IMPORT
}

// ========================
// Администраторы
// ========================

model AdminUser {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique
  passwordHash     String
  name             String
  role             AdminRole @default(EDITOR)
  isActive         Boolean   @default(true)
  refreshTokenHash String? // хеш refresh token для инвалидации
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("admin_users")
}

// ========================
// Пользователи сайта (аккаунты)
// ========================

model User {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique
  passwordHash     String
  name             String
  isActive         Boolean   @default(true)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  favorites UserFavorite[]

  @@map("users")
}

model UserFavorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  eventSlug String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventSlug])
  @@index([userId])
  @@map("user_favorites")
}

// ========================
// Аудит
// ========================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  action    String // CREATE | UPDATE | DELETE
  entity    String // "LandingPage" | "ComboPage" | ...
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ========================
// Города
// ========================

model City {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique
  name            String
  description     String?  @db.Text
  heroImage       String?
  lat             Decimal? @db.Decimal(10, 7)
  lng             Decimal? @db.Decimal(10, 7)
  timezone        String   @default("Europe/Moscow")
  metaTitle       String?
  metaDescription String?  @db.Text
  isFeatured      Boolean  @default(false)
  isActive        Boolean  @default(true)
  version         Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  events       Event[]
  venues       Venue[]
  packages     Package[]
  articles     Article[]
  landingPages LandingPage[]
  comboPages   ComboPage[]
  collections  Collection[]
  locations    Location[]

  // Регионы: город может быть хабом региона и/или входить в регион
  hubForRegions Region[]     @relation("RegionHub")
  regionLinks   RegionCity[]

  @@map("cities")
}

// ========================
// Регионы (группировка городов по области/зоне транспортной доступности)
// ========================

model Region {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String // "Татарстан", "Ленинградская область"
  description String?  @db.Text // SEO-текст для /regions/[slug]
  heroImage   String?
  hubCityId   String   @db.Uuid // Главный город (Казань, СПб, Москва)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hubCity City         @relation("RegionHub", fields: [hubCityId], references: [id])
  cities  RegionCity[]

  @@index([hubCityId])
  @@map("regions")
}

model RegionCity {
  regionId String @db.Uuid
  cityId   String @db.Uuid

  region Region @relation(fields: [regionId], references: [id])
  city   City   @relation(fields: [cityId], references: [id])

  @@id([regionId, cityId])
  @@index([cityId])
  @@map("region_cities")
}

// ========================
// События (из Ticketscloud / teplohod.info)
// ========================

model Event {
  id                  String             @id @default(uuid()) @db.Uuid
  source              EventSource        @default(TC)
  tcEventId           String?            @db.Text // TC: "6980...", Teplohod: "123"
  tcMetaEventId       String? // ID группы MetaEvent из TC (для повторяющихся)
  cityId              String             @db.Uuid
  title               String
  normalizedTitle     String?
  groupingKey         String?            @db.Text
  slug                String             @unique
  description         String?            @db.Text
  shortDescription    String?
  category            EventCategory
  subcategories       EventSubcategory[] @default([])
  audience            EventAudience      @default(ALL)
  minAge              Int                @default(0)
  durationMinutes     Int?
  lat                 Decimal?           @db.Decimal(10, 7)
  lng                 Decimal?           @db.Decimal(10, 7)
  address             String?
  indoor              Boolean?
  rating              Decimal            @default(0) @db.Decimal(2, 1)
  reviewCount         Int                @default(0)
  // Внешние рейтинги (ручной ввод из Яндекс.Карт / 2GIS / Tripadvisor)
  externalRating      Decimal?           @db.Decimal(2, 1)
  externalReviewCount Int?
  externalSource      String? // "yandex_maps" | "2gis" | "tripadvisor" | etc.
  imageUrl            String?
  galleryUrls         String[]
  priceFrom           Int? // в копейках
  isActive            Boolean            @default(true)
  tcData              Json? // оригинальные данные из TC
  lastSyncAt          DateTime?
  // === Soft-delete (финансовая безопасность) ===
  isDeleted           Boolean            @default(false)
  deletedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // === Supplier / Moderation ===
  supplierId       String?          @db.Uuid // Ссылка на оператора-поставщика
  moderationStatus ModerationStatus @default(APPROVED)
  moderationNote   String?
  moderatedAt      DateTime?
  moderatedBy      String?          @db.Uuid
  createdByType    CreatedByType?   @default(IMPORT)
  createdById      String?          @db.Uuid
  updatedById      String?          @db.Uuid

  // === Venue / DateMode (Музеи и Арт) ===
  venueId     String?   @db.Uuid
  dateMode    DateMode  @default(SCHEDULED)
  isPermanent Boolean   @default(false) // Постоянная экспозиция
  endDate     DateTime? // Дата окончания для временных выставок

  /// Default capacity for MANUAL sessions created in admin (Teplohod-style schedule).
  defaultCapacityTotal Int?

  // Дедупликация: если canonicalOfId задан — это дубль, скрывается из каталога
  canonicalOfId String? @db.Uuid
  canonicalOf   Event?  @relation("EventDuplicates", fields: [canonicalOfId], references: [id])
  duplicates    Event[] @relation("EventDuplicates")

  // Опциональные связи (Фаза 2 — Location/Operator/Route)
  startLocationId String? @db.Uuid
  endLocationId   String? @db.Uuid
  operatorId      String? @db.Uuid
  routeId         String? @db.Uuid

  city            City             @relation(fields: [cityId], references: [id])
  venue           Venue?           @relation("VenueEvents", fields: [venueId], references: [id])
  startLocation   Location?        @relation("EventStartLocation", fields: [startLocationId], references: [id])
  endLocation     Location?        @relation("EventEndLocation", fields: [endLocationId], references: [id])
  operator        Operator?        @relation(fields: [operatorId], references: [id])
  route           Route?           @relation(fields: [routeId], references: [id])
  offers          EventOffer[]
  sessions        EventSession[]
  tags            EventTag[]
  packageItems    PackageItem[]
  articleEvents   ArticleEvent[]
  override        EventOverride?
  reviews         Review[]
  externalReviews ExternalReview[]
  reviewRequests  ReviewRequest[]
  orderRequests   OrderRequest[]

  @@unique([source, tcEventId])
  @@index([source, tcEventId])
  @@index([cityId, category])
  @@index([groupingKey])
  @@index([groupingKey, cityId])
  @@index([slug])
  @@index([tcMetaEventId])
  @@index([canonicalOfId])
  @@index([venueId])
  @@index([operatorId])
  @@index([supplierId])
  @@index([startLocationId])
  @@index([endLocationId])
  @@index([routeId])
  @@map("events")
}

// Группа мульти-событий (одно шоу в разных городах/датах). Связь через groupingKey.
model EventGroup {
  id          String   @id @default(uuid()) @db.Uuid
  groupingKey String   @unique @db.Text
  slug        String   @unique
  title       String
  coverUrl    String?
  auto        Boolean  @default(true) // true = создано скриптом, false = вручную
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@map("event_groups")
}

model EventSession {
  id               String    @id @default(uuid()) @db.Uuid
  eventId          String    @db.Uuid
  offerId          String?   @db.Uuid // FK к EventOffer (nullable на переходном этапе)
  tcSessionId      String    @unique // Для MANUAL batch-create: "manual-{uuid}"
  startsAt         DateTime
  endsAt           DateTime?
  availableTickets Int       @default(0)
  /// Snapshot capacity per slot; if NULL, use Event.defaultCapacityTotal as default.
  capacityTotal    Int?
  prices           Json // [{type: "adult", price: 150000}, ...]
  isActive         Boolean   @default(true) // Пауза = false
  canceledAt       DateTime? // CANCELED = IS NOT NULL
  cancelReason     String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Restrict)
  offer        EventOffer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)
  packageItems PackageItem[]

  @@unique([eventId, startsAt])
  @@index([startsAt])
  @@index([eventId])
  @@index([eventId, startsAt])
   @@index([eventId, canceledAt])
  @@index([offerId])
  @@index([offerId, startsAt])
  @@map("event_sessions")
}

// ========================
// Event Offer (мульти-источник: TC, Teplohod, Radario...)
// ========================

model EventOffer {
  id                  String       @id @default(uuid()) @db.Uuid
  eventId             String       @db.Uuid
  source              OfferSource
  purchaseType        PurchaseType
  externalEventId     String? // tcEventId / "tep-123" / radario ID
  metaEventId         String? // TC metaEventId для повторяющихся
  deeplink            String? // Внешний URL для REDIRECT
  priceFrom           Int? // Мин. цена в копейках (из этого источника)
  commissionPercent   Float? // Наша комиссия %
  // --- Pricing / validity (для MANUAL/open-date офферов) ---
  priceMode           PriceMode    @default(FIXED_PRICE)
  validityMode        ValidityMode @default(NO_EXPIRY)
  validUntil          DateTime?
  validDays           Int?
  minAmount           Int?         // Мин. сумма (копейки) для OPEN_PRICE
  suggestedAmounts    Int[]        @default([]) // Предлагаемые суммы (копейки) для OPEN_PRICE
  status              OfferStatus  @default(ACTIVE)
  isPrimary           Boolean      @default(false)
  priority            Int          @default(0)
  availabilityMode    String? // "UNKNOWN" | "LIMITED" | "SOLD_OUT" | "BY_API"
  badge               String? // "optimal" | "cheapest" | "fastest" | custom
  operatorId          String?      @db.Uuid
  // --- WIDGET contract ---
  widgetProvider      String? // Провайдер виджета: "TC" | "RADARIO" | custom (может совпадать с source)
  widgetPayload       Json? // JSON-конфиг для виджета: { tokenKey, eventId, metaEventId, ... }
  // ---
  externalData        Json? // Оригинальные данные из источника
  venueId             String?      @db.Uuid // Прямой оффер к venue (билет в Эрмитаж)
  // --- Операционная информация (видна клиенту ПОСЛЕ подтверждения) ---
  meetingPoint        String? // Адрес/описание точки сбора
  meetingInstructions String?      @db.Text // Как добраться, где вход, ориентиры
  operationalPhone    String? // Контактный телефон на месте (НЕ офис поставщика)
  operationalNote     String?      @db.Text // Доп. инструкции (что взять с собой, дресс-код...)
  // ---
  lastSyncAt          DateTime?
  // === Soft-delete (нельзя удалять если есть OrderRequests/FulfillmentItems) ===
  isDeleted           Boolean      @default(false)
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Restrict)
  venue         Venue?         @relation("VenueOffers", fields: [venueId], references: [id])
  sessions      EventSession[]
  operator      Operator?      @relation(fields: [operatorId], references: [id])
  orderRequests OrderRequest[]

  @@unique([source, externalEventId])
  @@index([eventId])
  @@index([status])
  @@index([operatorId])
  @@index([venueId])
  @@map("event_offers")
}

// ========================
// Event Override (admin правки поверх sync-данных)
// ========================

model EventOverride {
  id            String             @id @default(uuid()) @db.Uuid
  eventId       String             @unique @db.Uuid
  title         String?
  description   String?            @db.Text
  imageUrl      String?
  category      EventCategory?
  subcategories EventSubcategory[] @default([])
  audience      EventAudience?
  minAge        Int?
  manualRating  Decimal?           @db.Decimal(2, 1)
  isHidden      Boolean            @default(false)
  tagsAdd       String[] // tag slugs to add
  tagsRemove    String[] // tag slugs to remove
  templateData  Json? // category-specific: route, menu, shipName (EXCURSION); program, cast, hall (EVENT)
  // --- Качество события (валидация перед публикацией) ---
  qualityStatus   String?   // DRAFT | READY | BLOCKED
  qualityIssues   Json?     // массив объектов { code, message, field? }
  qualityCheckedAt DateTime?
  // --- Семантика подкатегорий (override / clear / inherit) ---
  subcategoriesMode     SubcategoriesMode   @default(INHERIT)
  subcategoriesOverride EventSubcategory[]
  updatedBy     String?            @db.Uuid // null = создано sync (очередь постредакции)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // --- Очередь постредакции (админка) ---
  editorStatus   EditorStatus  @default(NEEDS_REVIEW)
  needsReviewAt  DateTime?     // сортировка очереди
  lastImportedAt DateTime?    // когда последний раз обновлялся импорт (Event.updatedAt)

  event Event @relation(fields: [eventId], references: [id], onDelete: Restrict)

  @@index([editorStatus, needsReviewAt])
  @@index([lastImportedAt])
  @@map("event_overrides")
}

// ========================
// Теги и лендинги
// ========================

model Tag {
  id              String      @id @default(uuid()) @db.Uuid
  slug            String      @unique
  name            String
  category        TagCategory
  description     String?     @db.Text
  heroImage       String?
  metaTitle       String?
  metaDescription String?     @db.Text
  isActive        Boolean     @default(true)
  isDeleted       Boolean     @default(false)
  deletedAt       DateTime?
  version         Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  events      EventTag[]
  articleTags ArticleTag[]

  @@map("tags")
}

model EventTag {
  eventId String @db.Uuid
  tagId   String @db.Uuid

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@index([tagId])
  @@map("event_tags")
}

// ========================
// Пакеты (Trip Planner)
// ========================

model Package {
  id           String        @id @default(uuid()) @db.Uuid
  code         String        @unique // "PKG-2026-ABCD12"
  email        String
  phone        String?
  customerName String
  cityId       String        @db.Uuid
  dateFrom     DateTime      @db.Date
  dateTo       DateTime      @db.Date
  adults       Int
  children     Int           @default(0)
  childrenAges Int[]
  intensity    Intensity
  variantName  String? // "Оптимальный"
  totalPrice   Int // в копейках
  serviceFee   Int           @default(0) // в копейках
  status       PackageStatus @default(DRAFT)
  paymentId    String? // YooKassa payment ID
  paidAt       DateTime?
  fulfilledAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  city    City          @relation(fields: [cityId], references: [id])
  items   PackageItem[]
  voucher Voucher?

  @@index([email])
  @@index([status])
  @@index([cityId])
  @@map("packages")
}

model PackageItem {
  id            String            @id @default(uuid()) @db.Uuid
  packageId     String            @db.Uuid
  eventId       String            @db.Uuid
  sessionId     String            @db.Uuid
  dayNumber     Int
  slot          DaySlot
  slotTime      String // "10:00"
  adultTickets  Int
  childTickets  Int               @default(0)
  subtotal      Int // в копейках
  tcOrderId     String? // TC order ID после создания
  tcOrderStatus String?
  status        PackageItemStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  package Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  event   Event        @relation(fields: [eventId], references: [id])
  session EventSession @relation(fields: [sessionId], references: [id])

  @@index([packageId])
  @@index([eventId])
  @@index([sessionId])
  @@map("package_items")
}

// ========================
// Ваучеры
// ========================

model Voucher {
  id        String    @id @default(uuid()) @db.Uuid
  packageId String    @unique @db.Uuid
  shortCode String    @unique // "V-ABCD12"
  qrCodeUrl String?
  pdfUrl    String?
  publicUrl String // https://daibilet.ru/v/V-ABCD12
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("vouchers")
}

// ========================
// Блог
// ========================

model Article {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique
  title           String
  content         String    @db.Text // Markdown
  excerpt         String?
  cityId          String?   @db.Uuid
  coverImage      String?
  metaTitle       String?
  metaDescription String?   @db.Text
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  version         Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  city          City?          @relation(fields: [cityId], references: [id])
  articleEvents ArticleEvent[]
  articleTags   ArticleTag[]

  @@index([cityId])
  @@map("articles")
}

model ArticleEvent {
  articleId String @db.Uuid
  eventId   String @db.Uuid

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([articleId, eventId])
  @@index([eventId])
  @@map("article_events")
}

model ArticleTag {
  articleId String @db.Uuid
  tagId     String @db.Uuid

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
  @@map("article_tags")
}

// ========================
// Combo-страницы (готовые программы, индексируемые)
// ========================

model ComboPage {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique // URL: /combo/:slug
  cityId          String    @db.Uuid
  title           String // "Романтический Петербург за 2 дня"
  subtitle        String?
  description     String?   @db.Text // SEO-текст
  heroImage       String?
  intensity       Intensity @default(NORMAL)
  dayCount        Int // 1, 2, 3...
  curatedEvents   Json // [{eventId, dayNumber, slot, time}]
  suggestedPrice  Int? // Ориентировочная цена (копейки)
  features        Json? // [{icon, title, text}] — USP
  includes        Json? // ["Билеты на 3 события", "Гид"]
  faq             Json? // [{question, answer}]
  metaTitle       String?
  metaDescription String?   @db.Text
  isActive        Boolean   @default(true)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  version         Int       @default(0)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  city City @relation(fields: [cityId], references: [id])

  @@index([cityId])
  @@map("combo_pages")
}

// ========================
// Посадочные страницы (лендинги)
// ========================

model LandingPage {
  id                String    @id @default(uuid()) @db.Uuid
  slug              String    @unique // URL: /cities/:citySlug/:slug
  cityId            String    @db.Uuid
  filterTag         String // slug тега для фильтрации событий
  additionalFilters Json? // {category?, source?, minDuration?, maxDuration?, features[]?}
  title             String // H1
  subtitle          String?
  heroText          String?   @db.Text
  howToChoose       Json? // [{title, text}]
  infoBlocks        Json? // [{title, text}]
  faq               Json? // [{question, answer}]
  reviews           Json? // [{text, author, rating}]
  stats             Json? // {soldTickets, avgRating}
  relatedLinks      Json? // [{title, href}]
  legalText         String?   @db.Text
  metaTitle         String?
  metaDescription   String?   @db.Text
  isActive          Boolean   @default(true)
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  version           Int       @default(0)
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  city City @relation(fields: [cityId], references: [id])

  @@index([cityId])
  @@map("landing_pages")
}

// ========================
// Подборки (тематические посадочные страницы)
// ========================

model Collection {
  id     String  @id @default(uuid()) @db.Uuid
  slug   String  @unique
  cityId String? @db.Uuid // null = кросс-городская

  // --- Фильтры (динамические события) ---
  filterTags        String[] // slug тегов (OR-логика)
  filterCategory    String? // EventCategory enum value
  filterSubcategory String? // EventSubcategory enum value
  filterAudience    String? // EventAudience enum value
  additionalFilters Json? // {maxDuration?, dateMode?, etc.}

  // --- Ручная курация ---
  pinnedEventIds   String[] @db.Uuid // всегда показывать первыми
  excludedEventIds String[] @db.Uuid // никогда не показывать

  // --- Контент ---
  title       String // H1
  subtitle    String?
  heroImage   String?
  description String? @db.Text // SEO-текст (markdown)
  infoBlocks  Json? // [{title, text}]
  faq         Json? // [{question, answer}]

  // --- SEO ---
  metaTitle       String?
  metaDescription String? @db.Text

  // --- Состояние ---
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  sortOrder Int       @default(0)
  version   Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  city City? @relation(fields: [cityId], references: [id])

  @@index([cityId])
  @@index([isActive, isDeleted])
  @@map("collections")
}

// ========================
// Pricing Config (singleton)
// ========================

model PricingConfig {
  id                  String   @id @default(uuid()) @db.Uuid
  serviceFeePercent   Float    @default(0)
  peakMarkupPercent   Float    @default(15)
  lastMinutePercent   Float    @default(10)
  tcCommissionPercent Float    @default(5)
  peakRanges          Json     @default("[]") // [{dateFrom, dateTo, cities?}]
  updatedBy           String?  @db.Uuid
  updatedAt           DateTime @updatedAt

  @@map("pricing_config")
}

// ========================
// Upsell Items
// ========================

model UpsellItem {
  id           String   @id @default(uuid()) @db.Uuid
  citySlug     String? // null = universal
  title        String
  description  String?
  priceKopecks Int
  category     String // photo, food, transfer, vip
  icon         String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("upsell_items")
}

// ========================
// Ops Status (singleton — статус последних операций)
// ========================

model OpsStatus {
  id             String    @id @default(uuid()) @db.Uuid
  lastFullSyncAt DateTime?
  lastIncrSyncAt DateTime?
  lastRetagAt    DateTime?
  lastPopulateAt DateTime?
  lastCacheFlush DateTime?
  lastError      String?
  updatedAt      DateTime  @updatedAt

  @@map("ops_status")
}

// ========================
// Venues (музеи, галереи, арт-пространства)
// ========================

model Venue {
  id               String         @id @default(uuid()) @db.Uuid
  cityId           String         @db.Uuid
  slug             String         @unique
  title            String // "Государственный Эрмитаж"
  shortTitle       String? // "Эрмитаж"
  venueType        VenueType
  description      String?        @db.Text // Markdown/HTML
  shortDescription String?
  imageUrl         String?
  galleryUrls      String[]       @default([]) // фото залов/экспозиций
  address          String?
  lat              Float?
  lng              Float?
  metro            String? // "Адмиралтейская"
  district         String?
  phone            String?
  email            String?
  website          String?
  openingHours     Json? // {"mon":"10:00-18:00","tue":"10:00-21:00",...,"wed":null}
  priceFrom        Int? // мин. цена (копейки)
  rating           Decimal        @default(0) @db.Decimal(2, 1)
  reviewCount      Int            @default(0)
  externalRating   Decimal?       @db.Decimal(2, 1)
  externalSource   String?
  operatorId       String?        @db.Uuid // партнер-музей
  isActive         Boolean        @default(true)
  isFeatured       Boolean        @default(false) // для главной
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  highlights       Json? // ["3 млн экспонатов","В центре города","Детям бесплатно"]
  faq              Json? // [{q:"Можно ли вернуть билет?",a:"Да, до начала визита"}]
  features         String[]       @default([]) // ["no_queue","audio_guide","kids_friendly","wheelchair"]
  commissionRate   Decimal?       @db.Decimal(4, 2) // Индивидуальная ставка (госмузеи и др.), админ может менять
  metaTitle        String?
  metaDescription  String?        @db.Text
  version          Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdByType    CreatedByType? @default(ADMIN)
  createdById      String?        @db.Uuid

  city     City         @relation(fields: [cityId], references: [id])
  operator Operator?    @relation("VenueOperator", fields: [operatorId], references: [id])
  events   Event[]      @relation("VenueEvents")
  offers   EventOffer[] @relation("VenueOffers")
  reviews  Review[]

  @@index([cityId])
  @@index([venueType])
  @@index([slug])
  @@index([operatorId])
  @@map("venues")
}

// ========================
// Локации (причалы, площадки, точки встречи)
// ========================

model Location {
  id         String       @id @default(uuid()) @db.Uuid
  cityId     String       @db.Uuid
  type       LocationType @default(OTHER)
  title      String
  shortTitle String?
  address    String?
  lat        Float?
  lng        Float?
  metro      String?
  district   String?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  city        City    @relation(fields: [cityId], references: [id])
  eventsStart Event[] @relation("EventStartLocation")
  eventsEnd   Event[] @relation("EventEndLocation")

  @@index([cityId, type])
  @@map("locations")
}

// ========================
// Операторы (организаторы)
// ========================

model Operator {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  slug          String         @unique
  logo          String?
  website       String?
  isActive      Boolean        @default(true)
  status        OperatorStatus @default(ACTIVE) // ACTIVE | ARCHIVED | SUSPENDED
  archivedAt    DateTime?
  archiveReason String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // === Supplier Portal ===
  isSupplier        Boolean   @default(false)
  trustLevel        Int       @default(0) // 0=модерация, 1=авто+постмод, 2=доверенный
  commissionRate    Decimal   @default(0.25) @db.Decimal(5, 4) // Базовая ставка 25% для всех (включает YooKassa)
  promoRate         Decimal?  @default(0.10) @db.Decimal(5, 4) // Промо-ставка 10% до promoUntil
  promoUntil        DateTime? // Окончание промо
  yookassaAccountId String? // Sub-merchant ID в YooKassa
  companyName       String?
  inn               String?
  contactEmail      String?
  contactPhone      String?
  verifiedAt        DateTime?
  successfulSales   Int       @default(0)
  refundRate        Decimal   @default(0) @db.Decimal(5, 4)

  // === Partner B2B API ===
  webhookUrl    String? // URL для отправки webhook-уведомлений
  webhookSecret String? // HMAC-секрет для подписи payload

  events        Event[]
  venues        Venue[]        @relation("VenueOperator")
  reviews       Review[]
  offers        EventOffer[]
  supplierUsers SupplierUser[]
  apiKeys       ApiKey[]

  @@map("operators")
}

// ========================
// API-ключи (Partner B2B)
// ========================

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  operatorId  String    @db.Uuid
  keyHash     String    @unique // SHA-256 хеш ключа
  prefix      String // Первые 8 символов (dbl_xxxx)
  name        String    @default("default")
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  rateLimit   Int       @default(100) // запросов/минуту
  ipWhitelist String[] // разрешённые IP (пустой = все)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id])

  @@index([operatorId])
  @@map("api_keys")
}

// ========================
// Поставщики (авторизация)
// ========================

model SupplierUser {
  id               String       @id @default(uuid()) @db.Uuid
  operatorId       String       @db.Uuid
  email            String       @unique
  passwordHash     String
  name             String
  role             SupplierRole @default(MANAGER)
  isActive         Boolean      @default(true)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id])

  @@index([operatorId])
  @@map("supplier_users")
}

// ========================
// Маршруты
// ========================

model Route {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  slug             String   @unique
  description      String?  @db.Text
  pointsOfInterest String[]
  estimatedMinutes Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  events Event[]

  @@map("routes")
}

// ========================
// Отзывы
// ========================

model Review {
  id           String       @id @default(uuid()) @db.Uuid
  eventId      String?      @db.Uuid // Отзыв на конкретное событие
  operatorId   String?      @db.Uuid // Отзыв на оператора (будущее)
  venueId      String?      @db.Uuid // Отзыв на место (музей, галерея)
  rating       Int // 1-5
  title        String? // Заголовок отзыва (опционально)
  text         String       @db.Text
  authorName   String
  authorEmail  String // Скрыто, для антидупликации
  isVerified   Boolean      @default(false) // Подтверждённая покупка
  voucherCode  String? // Код ваучера (если верифицированный)
  verifyToken  String?      @unique // Токен для email-верификации
  helpfulCount Int          @default(0) // Кэш количества полезных голосов
  status       ReviewStatus @default(PENDING_EMAIL)
  adminComment String? // Причина отклонения
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  event    Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  operator Operator?     @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  venue    Venue?        @relation(fields: [venueId], references: [id], onDelete: SetNull)
  photos   ReviewPhoto[]
  votes    ReviewVote[]

  @@unique([authorEmail, eventId, venueId])
  @@index([eventId, status])
  @@index([operatorId, status])
  @@index([venueId, status])
  @@index([status])
  @@map("reviews")
}

// ========================
// Фото отзывов
// ========================

model ReviewPhoto {
  id            String   @id @default(uuid()) @db.Uuid
  reviewId      String   @db.Uuid
  url           String // /uploads/reviews/uuid.webp
  thumbUrl      String // /uploads/reviews/uuid-thumb.webp
  filename      String // uuid.webp (для удаления)
  thumbFilename String // uuid-thumb.webp
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_photos")
}

// ========================
// Голоса за отзывы ("Полезный отзыв")
// ========================

model ReviewVote {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @db.Uuid
  ipHash    String // SHA-256 от IP для дедупликации
  isHelpful Boolean
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, ipHash])
  @@index([reviewId])
  @@map("review_votes")
}

// ========================
// Внешние отзывы (Яндекс.Карты, 2GIS, Tripadvisor, Google)
// ========================

model ExternalReview {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String?   @db.Uuid
  operatorId  String?   @db.Uuid
  source      String // "yandex_maps" | "2gis" | "tripadvisor" | "google"
  sourceUrl   String? // Ссылка на оригинальный отзыв
  authorName  String
  rating      Int // 1-5
  text        String    @db.Text
  publishedAt DateTime? // Дата оригинального отзыва
  createdAt   DateTime  @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId, source])
  @@index([operatorId])
  @@map("external_reviews")
}

// ========================
// Запросы на отзыв (пост-покупочный flow)
// ========================

model ReviewRequest {
  id             String    @id @default(uuid()) @db.Uuid
  email          String
  eventId        String    @db.Uuid
  token          String    @unique // Токен для прямой ссылки на форму
  sentAt         DateTime  @default(now())
  reminderSentAt DateTime? // Дата повторного напоминания
  openedAt       DateTime? // Tracking по pixel (опционально)
  clickedAt      DateTime? // Клик по ссылке
  reviewId       String?   @db.Uuid // Связь с оставленным отзывом

  event Event @relation(fields: [eventId], references: [id])

  @@unique([email, eventId])
  @@index([token])
  @@index([eventId])
  @@map("review_requests")
}

// ========================
// Checkout & Заявки
// ========================

enum CheckoutStatus {
  STARTED // Корзина сформирована, данные отправлены
  VALIDATED // Серверная валидация пройдена
  REDIRECTED // Перенаправлен к провайдеру (Сценарий 1)
  PENDING_CONFIRMATION // Заявка, ждёт подтверждения оператором (Сценарий 2)
  CONFIRMED // Места подтверждены
  AWAITING_PAYMENT // Подтверждено, ожидает оплату
  COMPLETED // Завершён
  EXPIRED // TTL истёк
  CANCELLED // Отменён
}

model CheckoutSession {
  id                             String            @id @default(uuid()) @db.Uuid
  shortCode                      String            @unique // "CS-XXXX" для UI
  cartSnapshot                   Json // Снимок корзины из localStorage
  validatedSnapshot              Json? // Результат validate (актуальные цены/наличие)
  offersSnapshot                 Json? // Immutable: данные офферов на момент оформления (title, price, type, deeplink, widgetPayload)
  giftCertificateSnapshot        Json? // Подарочный сертификат: { amount, recipientEmail, senderName?, message? }
  appliedGiftCertificateSnapshot Json? // Применённый код: { certificateId, code, discountAmount }
  customerName                   String?
  customerEmail                  String?
  customerPhone                  String?
  status                         CheckoutStatus    @default(STARTED)
  totalPrice                     Int? // Итого в копейках
  expiresAt                      DateTime? // TTL для soft-reserve
  completedAt                    DateTime? // Когда сессия завершена (для аналитики)
  utmSource                      String?
  utmMedium                      String?
  utmCampaign                    String?
  referrer                       String?
  userAgent                      String?
  ip                             String?
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt
  orderRequests                  OrderRequest[]
  paymentIntents                 PaymentIntent[]
  fulfillmentItems               FulfillmentItem[]
  giftCertificate                GiftCertificate?

  @@index([status])
  @@index([customerEmail])
  @@index([status, expiresAt])
  @@map("checkout_sessions")
}

// ========================
// Подарочные сертификаты
// ========================

model GiftCertificate {
  id                String    @id @default(uuid()) @db.Uuid
  checkoutSessionId String    @unique @db.Uuid
  amount            Int // Номинал в копейках
  code              String    @unique // Уникальный код (V-XXXX-XXXX)
  recipientEmail    String
  senderName        String?
  message           String?   @db.Text
  status            String    @default("ISSUED") // ISSUED | ACTIVATED | EXPIRED
  issuedAt          DateTime  @default(now())
  activatedAt       DateTime? // Когда применён к заказу
  expiresAt         DateTime? // Срок действия (null = бессрочно)

  checkoutSession CheckoutSession @relation(fields: [checkoutSessionId], references: [id])

  @@index([code])
  @@index([recipientEmail])
  @@index([status])
  @@map("gift_certificates")
}

model OrderRequest {
  id                String    @id @default(uuid()) @db.Uuid
  checkoutSessionId String?   @db.Uuid // Nullable для quick-request (без корзины)
  eventOfferId      String    @db.Uuid
  eventId           String    @db.Uuid
  sessionId         String?   @db.Uuid // Если выбран конкретный сеанс
  quantity          Int       @default(1)
  priceSnapshot     Int // Цена на момент оформления (копейки)
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  customerComment   String?
  status            String    @default("PENDING") // PENDING | CONFIRMED | REJECTED | EXPIRED
  slaMinutes        Int       @default(30) // SLA: ожидаемое время реакции оператора (мин)
  expireReason      String? // "SLA" | "TTL" | "CART" — причина истечения
  adminNote         String?
  confirmedAt       DateTime?
  expiresAt         DateTime? // TTL: явная дата/время истечения заявки
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id])
  event           Event            @relation(fields: [eventId], references: [id])
  eventOffer      EventOffer       @relation(fields: [eventOfferId], references: [id])

  @@index([checkoutSessionId])
  @@index([status])
  @@index([eventId])
  @@index([eventOfferId])
  @@index([status, expiresAt]) // Для cron-выборки PENDING + expiresAt < now
  @@map("order_requests")
}

// ========================
// Payments (YooKassa-ready)
// ========================

enum PaymentStatus {
  PENDING // Ожидает инициации / оплаты
  PROCESSING // В обработке (redirect / waiting)
  PAID // Оплачено
  FAILED // Ошибка оплаты
  CANCELLED // Отменён пользователем
  REFUNDED // Возврат
}

model PaymentIntent {
  id                String        @id @default(uuid()) @db.Uuid
  checkoutSessionId String        @db.Uuid
  idempotencyKey    String        @unique
  amount            Int // Сумма в копейках
  currency          String        @default("RUB")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("STUB")
  providerPaymentId String?
  providerData      Json?
  paymentUrl        String?
  paidAt            DateTime?
  failedAt          DateTime?
  failReason        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // === Split Payment (маркетплейс) ===
  supplierId     String?  @db.Uuid
  grossAmount    Int? // Полная сумма от клиента (копейки)
  platformFee    Int? // Комиссия платформы (копейки)
  supplierAmount Int? // Сумма поставщику (копейки)
  commissionRate Decimal? @db.Decimal(5, 4) // Ставка на момент транзакции
  splitPaymentId String? // ID split-платежа YooKassa

  checkoutSession CheckoutSession @relation(fields: [checkoutSessionId], references: [id])

  @@index([checkoutSessionId])
  @@index([status])
  @@index([provider, providerPaymentId])
  @@index([supplierId])
  @@map("payment_intents")
}

// ========================
// Fulfillment (per-line-item execution)
// ========================

enum PurchaseFlow {
  PLATFORM // Оплата через нашу платформу (YooKassa)
  EXTERNAL // Оплата у внешнего провайдера (TC widget, redirect)
}

enum FulfillmentStatus {
  PENDING // Ожидает исполнения
  RESERVING // В процессе резервирования
  RESERVED // Зарезервировано у провайдера
  CONFIRMED // Подтверждено провайдером
  FAILED // Ошибка (исчерпаны ретраи)
  CANCELLED // Отменено
  REFUNDED // Возврат выполнен
}

model FulfillmentItem {
  id                 String            @id @default(uuid()) @db.Uuid
  checkoutSessionId  String            @db.Uuid
  lineItemIndex      Int // Индекс позиции в offersSnapshot
  offerId            String            @db.Uuid
  purchaseFlow       PurchaseFlow // PLATFORM | EXTERNAL
  provider           String            @default("INTERNAL") // TC | TEP | INTERNAL | PARTNER
  status             FulfillmentStatus @default(PENDING)
  externalOrderId    String? // ID заказа у провайдера (TC order id, etc.)
  externalPaymentUrl String? // Ссылка на оплату у провайдера
  providerData       Json? // Данные от провайдера
  amount             Int // Сумма позиции в копейках
  refundedAmount     Int               @default(0) // Возвращённая сумма в копейках
  refundId           String? // ID рефанда (YooKassa)
  attemptCount       Int               @default(0) // Количество попыток
  nextRetryAt        DateTime? // Следующая попытка
  lastError          String? // Последняя ошибка
  escalatedAt        DateTime? // Когда эскалировано админу
  resolvedBy         String?           @db.Uuid // ID админа, вмешавшегося вручную
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  checkoutSession CheckoutSession @relation(fields: [checkoutSessionId], references: [id])

  @@index([checkoutSessionId])
  @@index([offerId])
  @@index([status])
  @@index([status, nextRetryAt]) // Для cron retry
  @@index([status, escalatedAt]) // Для cron auto-compensate
  @@map("fulfillment_items")
}

// ========================
// Webhook — raw event log (accept & log, idempotent)
// ========================

model PaymentEventLog {
  id             String   @id @default(uuid()) @db.Uuid
  provider       String // YOOKASSA | TC | PARTNER
  eventType      String // payment.succeeded, payment.canceled, etc.
  paymentId      String // ID платежа (object.id от YK)
  idempotencyKey String // eventType + paymentId (для дедупликации)
  payload        Json // Raw payload webhook
  receivedAt     DateTime @default(now())

  @@unique([provider, eventType, paymentId])
  @@index([provider, eventType])
  @@map("payment_event_logs")
}

// ========================
// Webhook Idempotency (ProcessedWebhookEvent)
// ========================

model ProcessedWebhookEvent {
  id              String   @id @default(uuid()) @db.Uuid
  providerEventId String   @unique // Ключ идемпотентности (payment.id от YK, etc.)
  provider        String // YOOKASSA | TC | PARTNER
  eventType       String // payment.succeeded, payment.canceled, etc.
  payload         Json // Полный payload для аудита
  result          String? // PAID | FAILED | IGNORED | etc.
  paymentIntentId String?  @db.Uuid // Трассировка: к какому PaymentIntent относится
  processedAt     DateTime @default(now())

  @@index([provider, eventType])
  @@index([paymentIntentId])
  @@map("processed_webhook_events")
}

// ========================
// Generic Idempotency (Batch 1 — Ops Foundation)
// ========================

enum IdempotencyScope {
  YOOKASSA_WEBHOOK // Процессинг webhook YooKassa
  CHECKOUT_CREATE // Создание Package/CheckoutSession
  EMAIL_SEND // Отправка email (dedup по template+recipient)
  EXTERNAL_CALLBACK // Внешние callbacks/partner webhooks
}

model IdempotencyKey {
  id        String           @id @default(cuid())
  scope     IdempotencyScope
  key       String
  entityId  String?          @db.Uuid
  status    String // IN_PROGRESS | DONE | FAILED
  response  Json? // Cached result when DONE
  metaJson  Json?
  createdAt DateTime         @default(now())
  expiresAt DateTime?

  @@unique([scope, key])
  @@index([expiresAt])
  @@index([entityId])
  @@index([status])
  @@map("idempotency_keys")
}

// ========================
// Feature Flags
// ========================

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String // e.g. "disable_external_offers"
  scope       String   @default("global") // global | city | category
  scopeValue  String? // cityId / category slug (null для global)
  enabled     Boolean  @default(false)
  metadata    Json? // Дополнительные параметры
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, scope, scopeValue])
  @@index([key, scope])
  @@map("feature_flags")
}

// ========================
// External Widgets (Teplohod.info и др.)
// ========================

enum ExternalWidgetProviderKind {
  TEPLOHOD
}

model ExternalWidgetProvider {
  id        String                     @id @default(cuid())
  kind      ExternalWidgetProviderKind @unique
  name      String
  baseUrl   String?
  isActive  Boolean                    @default(true)
  metaJson  Json?
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  widgets   ExternalWidget[]

  @@index([isActive])
  @@map("external_widget_providers")
}

model ExternalWidget {
  id         String                 @id @default(cuid())
  providerId String
  provider   ExternalWidgetProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  externalId String // widgetId из teplohod.info
  title      String?
  url        String?
  metaJson   Json?
  isActive   Boolean                @default(true)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([providerId, externalId])
  @@index([providerId])
  @@index([isActive])
  @@index([updatedAt])
  @@map("external_widgets")
}

// ========================
// Query Filters (QF) — справочник быстрых фильтров
// ========================

model QueryFilter {
  id       String  @id @default(cuid())
  type     String  // excursion | venue | event
  group    String
  slug     String
  title    String
  isSeo    Boolean @default(false)
  priority Int     @default(0)

  @@unique([slug, type])
  @@index([type])
  @@index([type, group])
  @@map("query_filters")
}

// ════════════════════════════════════════════
// SUPPORT TICKETS
// ════════════════════════════════════════════

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketCategory {
  ORDER
  REFUND
  VENUE
  TECHNICAL
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id          String         @id @default(uuid()) @db.Uuid
  shortCode   String         @unique // ST-XXXX
  name        String
  email       String
  phone       String?
  category    TicketCategory @default(OTHER)
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  subject     String // Краткое описание
  message     String         @db.Text // Первое сообщение
  orderCode   String? // Связь с заказом (CS-XXXX)
  assignedTo  String?        @db.Uuid // ID администратора
  resolvedAt  DateTime?
  slaDeadline DateTime? // Дедлайн SLA ответа
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  responses TicketResponse[]

  @@index([status])
  @@index([email])
  @@index([orderCode])
  @@index([category, status])
  @@index([assignedTo])
  @@map("support_tickets")
}

model TicketResponse {
  id         String   @id @default(uuid()) @db.Uuid
  ticketId   String   @db.Uuid
  authorType String   @default("admin") // admin | system | customer
  authorName String?
  message    String   @db.Text
  isInternal Boolean  @default(false) // Внутренняя заметка (не видна клиенту)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_responses")
}
