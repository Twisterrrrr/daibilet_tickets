<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if hasVoucher}}Заказ готов{{else}}{{#if hasQr}}Ваш билет{{else}}Как прошёл визит?{{/if}}{{/if}}</title>
</head>
<body style="margin:0;padding:0;background:#f5f5f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;margin:0 auto;background:#fff;border-radius:12px;overflow:hidden;margin-top:32px;margin-bottom:32px;">
    <tr>
      <td style="background:#2563eb;padding:24px 32px;">
        <h1 style="color:#fff;margin:0;font-size:22px;">🎉 Дайбилет</h1>
      </td>
    </tr>
    <tr>
      <td style="padding:32px;">
        {{#if hasVoucher}}
        <h2 style="color:#1a1a1a;margin:0 0 16px;">Ваш ваучер готов</h2>
        <p style="color:#555;line-height:1.6;margin:0 0 16px;">
          {{customerName}}, заказ {{shortCode}} полностью выполнен.
        </p>
        <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
          <tr>
            <td style="background:#f0fdf4;padding:16px;font-size:14px;">
              {{#if voucherCode}}
              <p style="margin:0 0 8px;"><strong>Код ваучера:</strong></p>
              <p style="margin:0;font-family:monospace;font-size:18px;letter-spacing:2px;">{{voucherCode}}</p>
              {{/if}}
              {{#if voucherUrl}}
              <p style="margin:12px 0 0;"><a href="{{voucherUrl}}" style="color:#2563eb;">Скачать ваучер</a></p>
              {{/if}}
            </td>
          </tr>
        </table>
        {{/if}}
        {{#if hasQr}}
        <h2 style="color:#1a1a1a;margin:0 0 16px;">Ваш билет</h2>
        <p style="color:#555;line-height:1.6;margin:0 0 16px;">
          {{customerName}}, покажите этот QR-код на месте.
        </p>
        <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;text-align:center;">
          <tr>
            <td style="padding:24px;">
              {{#if qrImageUrl}}
              <img src="{{qrImageUrl}}" alt="QR-код билета" width="180" height="180" style="display:block;margin:0 auto 12px;" />
              {{/if}}
              {{#if qrData}}
              <p style="margin:0;font-size:12px;color:#6b7280;">Код: <code style="background:#f3f4f6;padding:2px 6px;border-radius:4px;">{{qrData}}</code></p>
              {{/if}}
            </td>
          </tr>
        </table>
        {{/if}}
        {{#unless hasVoucher}}
        {{#unless hasQr}}
        <h2 style="color:#1a1a1a;margin:0 0 16px;">Как прошёл визит?</h2>
        <p style="color:#555;line-height:1.6;margin:0 0 12px;">
          {{customerName}}, надеемся, вам понравилось!
        </p>
        <p style="color:#555;line-height:1.6;margin:0 0 24px;">
          Расскажите о впечатлениях от <strong>{{eventTitle}}</strong> — ваш отзыв поможет другим путешественникам.
        </p>
        {{#if reviewUrl}}
        <table cellpadding="0" cellspacing="0" style="margin:0 auto 24px;">
          <tr>
            <td style="background:#2563eb;border-radius:8px;">
              <a href="{{reviewUrl}}" style="display:inline-block;padding:14px 32px;color:#fff;text-decoration:none;font-size:16px;font-weight:600;">
                Оставить отзыв
              </a>
            </td>
          </tr>
        </table>
        {{/if}}
        {{/unless}}
        {{/unless}}

        <p style="color:#999;font-size:13px;line-height:1.5;margin:0;">
          Заказ {{shortCode}} · <a href="{{trackUrl}}" style="color:#2563eb;">Детали заказа</a>
        </p>
      </td>
    </tr>
    <tr>
      <td style="background:#f9fafb;padding:16px 32px;border-top:1px solid #eee;">
        <p style="color:#999;font-size:12px;margin:0;text-align:center;">
          <a href="{{appUrl}}" style="color:#999;">daibilet.ru</a> — лучшие экскурсии и развлечения
        </p>
      </td>
    </tr>
  </table>
</body>
</html>
